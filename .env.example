# ── LLM providers (router — see the `llm:` block in tenant.yaml) ───────────
# Only set keys for the providers your tenant's `llm:` block actually uses.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=                    # OpenAI-compatible: OpenAI, local Ollama, or imago.market
OPENAI_BASE_URL=
MISTRAL_API_KEY=                   # optional — pip install "go-to-market-agent[mistral]"
GOOGLE_API_KEY=                    # optional — pip install "go-to-market-agent[google]"

# ── Research + data sources ────────────────────────────────
# None of these are needed for `make demo` (it runs on bundled fixtures).
TAVILY_API_KEY=                    # web research (free tier available)
APIFY_TOKEN=                       # Instagram / Ad Library / SimilarWeb enrichment
# Paid SEO sources — needed only if you enable the Ahrefs / DataForSEO sources:
AHREFS_API_KEY=
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# ── Storage ────────────────────────────────────────────────
# DATABASE_URL=                    # storage defaults to local SQLite (./data/state.db); Postgres = optional extra

# ── Optional output + notification adapters ────────────────
NOTION_TOKEN=                      # optional Notion output adapter
NOTION_PARENT_PAGE_ID=
TELEGRAM_BOT_TOKEN=                # optional — pip install "go-to-market-agent[telegram]"
TELEGRAM_CHAT_ID=
SLACK_WEBHOOK_URL=                 # optional alerting/teaser seam

LOG_LEVEL=INFO
